{#
    7-column search history table (Date · Type · Query · Results · Tokens · Cost · Duration).
    Shared by history/index.twig and insights/index.twig (history tab).

    Params:
        items     iterable of history rows
        urlPath   string  cpUrl base, e.g. 'ai-search/history' or 'ai-search/insights'

    Usage:
        {% include 'ai-search/_partials/search-history-table' with {
            items: page.items, urlPath: 'ai-search/history'
        } only %}
#}
{% set cachedTitle = cachedTitle ?? 'Embedding served from cache' %}
<table class="data fullwidth">
    <thead>
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Query</th>
            <th class="rightalign">Results</th>
            <th class="rightalign">Tokens</th>
            <th class="rightalign">Cost</th>
            <th class="rightalign">Duration</th>
        </tr>
    </thead>
    <tbody>
        {% for item in items %}
            {% set href = cpUrl(urlPath ~ '/' ~ item.id) %}
            <tr>
                <td><a href="{{ href }}">{{ item.dateCreated|date('M j, Y g:i:s A') }}</a></td>
                <td>
                    <span class="status {% if item.type == 'rag' %}on{% else %}orange{% endif %}"></span>
                    {{ item.type }}
                    {% if item.hasError %}<span class="status off" title="Error"></span>{% endif %}
                </td>
                <td>
                    {% if item.detailsId %}
                        <a href="{{ href }}">{{ item.query|slice(0, 120) }}{% if item.query|length > 120 %}…{% endif %}</a>
                    {% else %}
                        <span class="light">— cleared</span>
                    {% endif %}
                </td>
                <td class="rightalign">{{ item.resultsCount }}</td>
                <td class="rightalign">{{ item.totalTokens|number_format }}{% if item.embeddingCached %} <span class="light" title="{{ cachedTitle }}">·c</span>{% endif %}</td>
                <td class="rightalign">${{ item.cost|number_format(6) }}</td>
                <td class="rightalign">{{ item.durationMs|number_format }} ms</td>
            </tr>
        {% else %}
            <tr><td colspan="7" class="centeralign light">No searches recorded yet.</td></tr>
        {% endfor %}
    </tbody>
</table>
