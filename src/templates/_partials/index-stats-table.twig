{#
    Small key/value table showing index statistics.
    Shared by data-sync.twig and index-mgmt/index.twig (overview tab).

    Params:
        stats   object  { entryCount, chunkCount, lastIndexed }
        labels  object  { database, entries, chunks, lastUpdated, connected, never }
#}
{% set labels = labels ?? {} %}
{% set L = {
    database: 'Database', entries: 'Indexed entries', chunks: 'Total chunks',
    lastUpdated: 'Last updated', connected: 'Connected', never: 'Never',
    dateFormat: 'F j, Y g:i a',
}|merge(labels) %}

<table class="data fullwidth">
    <tbody>
        <tr>
            <th class="light">{{ L.database }}</th>
            <td><span class="status on"></span> {{ L.connected }}</td>
        </tr>
        <tr>
            <th class="light">{{ L.entries }}</th>
            <td data-craftsearch-target="stat-entries">{{ stats.entryCount|number_format }}</td>
        </tr>
        <tr>
            <th class="light">{{ L.chunks }}</th>
            <td data-craftsearch-target="stat-chunks">{{ stats.chunkCount|number_format }}</td>
        </tr>
        <tr>
            <th class="light">{{ L.lastUpdated }}</th>
            <td>
                {% if stats.lastIndexed %}
                    {{ stats.lastIndexed|date(L.dateFormat) }}
                {% else %}
                    {{ L.never }}
                {% endif %}
            </td>
        </tr>
    </tbody>
</table>
