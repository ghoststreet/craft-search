{#
    A single site's index health card on the Overview tab.

    Params:
        site         object  per-site row (siteId, name, handle, indexed, stale, notIndexed, total, chunkCount, lastIndexed)
        isMultiSite  bool    when false, the Sync button label is "Sync index" instead of "Sync this site"
#}
{% set hasGaps = site.stale > 0 or site.notIndexed > 0 %}
{% set coverage = site.total > 0 ? (site.indexed / site.total * 100)|round : 0 %}

<div class="craftsearch-card{% if hasGaps %} craftsearch-card--warn{% endif %}" data-craftsearch-site-id="{{ site.siteId }}">
    <div class="craftsearch-card__head">
        <h3 class="craftsearch-card__title">{{ site.name }}</h3>
        {% if hasGaps %}
            <span class="craftsearch-card__pill craftsearch-card__pill--warn">
                <span class="status orange"></span> Needs sync
            </span>
        {% else %}
            <span class="craftsearch-card__pill craftsearch-card__pill--ok">
                <span class="status on"></span> Healthy
            </span>
        {% endif %}
    </div>

    <div class="craftsearch-card__hero">
        <div class="craftsearch-card__hero-number">
            {{ site.indexed }}<span class="craftsearch-card__hero-total"> / {{ site.total }}</span>
        </div>
        <div class="craftsearch-card__hero-label">entries indexed · {{ coverage }}%</div>
    </div>

    {% if hasGaps %}
        <ul class="craftsearch-card__gaps">
            {% if site.stale > 0 %}
                <li><span class="status orange"></span> <strong>{{ site.stale }}</strong> stale <span class="light">(edited since last sync)</span></li>
            {% endif %}
            {% if site.notIndexed > 0 %}
                <li><span class="status off"></span> <strong>{{ site.notIndexed }}</strong> not indexed <span class="light">(never embedded)</span></li>
            {% endif %}
        </ul>
    {% endif %}

    <div class="craftsearch-card__progress" data-craftsearch-target="site-progress" hidden>
        <p class="light smalltext" data-craftsearch-target="site-progress-label">Queued…</p>
        <div data-craftsearch-target="site-progress-bar"></div>
        <p class="error smalltext" data-craftsearch-target="site-progress-error" hidden></p>
    </div>

    <div class="craftsearch-card__footer">
        <div class="craftsearch-card__meta">
            <span data-craftsearch-stat="lastSync">
                {% if site.lastIndexed %}
                    Last sync {{ site.lastIndexed|date('M j, g:i a') }}
                {% else %}
                    Never synced
                {% endif %}
            </span>
            <span class="light">·</span>
            <span class="light"><span data-craftsearch-stat="chunks">{{ site.chunkCount|number_format }}</span> chunks</span>
        </div>
        <form method="post">
            {{ csrfInput() }}
            {{ actionInput('ai-search/index/sync') }}
            <input type="hidden" name="siteId" value="{{ site.siteId }}">
            <button type="submit" class="btn{% if hasGaps %} craftsearch-btn--danger{% else %} submit{% endif %}" data-craftsearch-control="sync-site-btn">
                {{ isMultiSite ? 'Sync this site' : 'Sync index' }}
            </button>
        </form>
    </div>
</div>
