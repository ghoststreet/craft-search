{% extends "_layouts/cp" %}

{% set title = 'Indexing Debug'|t('ai-search') %}
{% set fullPageForm = false %}

{% set crumbs = [
    { label: 'AI Search', url: cpUrl('ai-search') },
] %}

{% set counts = result.counts ?? { indexed: 0, stale: 0, 'not-indexed': 0, total: result.total } %}
{% set totalPages = (result.total / result.pageSize)|round(0, 'ceil') %}

{% set toolbarLabels = {
    site: 'Site'|t('ai-search'),
    section: 'Section'|t('ai-search'),
    status: 'Status'|t('ai-search'),
    all: 'All'|t('ai-search'),
    allSections: 'All sections'|t('ai-search'),
    indexed: 'Indexed'|t('ai-search'),
    stale: 'Stale'|t('ai-search'),
    notIndexed: 'Not indexed'|t('ai-search'),
    filter: 'Filter'|t('ai-search'),
} %}

{% set tableLabels = {
    title: 'Title'|t('ai-search'),
    section: 'Section'|t('ai-search'),
    status: 'Status'|t('ai-search'),
    chunks: 'Chunks'|t('ai-search'),
    lastIndexed: 'Last indexed'|t('ai-search'),
    indexed: 'Indexed'|t('ai-search'),
    stale: 'Stale'|t('ai-search'),
    notIndexed: 'Not indexed'|t('ai-search'),
    emptyMessage: 'No entries match these filters.'|t('ai-search'),
    untitled: '(untitled)'|t('ai-search'),
} %}

{% set statsLabels = {
    total: 'Total'|t('ai-search'),
    indexed: 'Indexed'|t('ai-search'),
    stale: 'Stale'|t('ai-search'),
    notIndexed: 'Not indexed'|t('ai-search'),
} %}

{% block content %}
    {% if error %}
        <div class="readable">
            <blockquote class="note warning">
                <p><strong>{{ 'Database error.'|t('ai-search') }}</strong> {{ error }}</p>
            </blockquote>
        </div>
    {% endif %}

    {% include 'ai-search/_partials/entries-toolbar' with {
        filters: filters,
        sites: sites,
        sections: sections,
        formClass: 'search-toolbar',
        labels: toolbarLabels,
    } only %}

    {% include 'ai-search/_partials/entries-stats' with { counts: counts, labels: statsLabels } only %}

    {% include 'ai-search/_partials/entries-table' with {
        rows: result.rows,
        entryUrlPath: 'ai-search/debug/entry',
        labels: tableLabels,
    } only %}

    {% include 'ai-search/_components/pagination-path' with {
        currentPage: result.page,
        totalPages: totalPages,
        params: filters,
        prevLabel: 'Prev'|t('ai-search'),
        nextLabel: 'Next'|t('ai-search'),
        pageLabel: 'Page {p} of {t}'|t('ai-search', { p: result.page, t: totalPages }),
    } only %}
{% endblock %}
