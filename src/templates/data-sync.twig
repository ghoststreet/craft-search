{% extends "_layouts/cp" %}

{% set title = 'Data Sync' %}
{% set selectedSubnavItem = 'data-sync' %}

{% block content %}
    <h2>Content Indexing</h2>
    <p class="light">AI Search automatically indexes your content when entries are saved. Use this page to view the current index status and rebuild it if needed.</p>

    <p class="light">All entries with valid URLs are indexed (excludes drafts and revisions), including matrix blocks and related content. Long content is automatically split into searchable chunks.</p>

    <hr>

    {% if setup.ready %}
        <h2>Index Statistics</h2>

        {% include 'ai-search/_partials/index-stats-table' with {
            stats: stats,
            labels: { database: 'Database Status', entries: 'Indexed Entries', chunks: 'Total Chunks', lastUpdated: 'Last Updated' },
        } only %}
    {% else %}
        <h2>Finish Setup</h2>
        <p class="light">Complete these steps to enable AI Search indexing. Each step links to where it can be fixed.</p>

        <table class="data fullwidth collapsible">
            <tbody>
                <tr>
                    <td class="thin centeralign">
                        {% if setup.credentials %}
                            <span class="success" data-icon="check" aria-label="Complete"></span>
                        {% else %}
                            <span class="error" data-icon="error" aria-label="Required"></span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ cpUrl('ai-search/settings') }}">Configure your PostgreSQL credentials</a>
                        {% if not setup.credentials %}
                            <div class="light smalltext">Host, database, user, and password are all required.</div>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <td class="thin centeralign">
                        {% if setup.connection %}
                            <span class="success" data-icon="check" aria-label="Complete"></span>
                        {% elseif setup.credentials %}
                            <span class="error" data-icon="error" aria-label="Required"></span>
                        {% else %}
                            <span class="warning" data-icon="alert" aria-label="Pending"></span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ cpUrl('ai-search/settings') }}">Connect to your vector database</a>
                        {% if setup.credentials and not setup.connection and setup.error %}
                            <div class="light smalltext">{{ setup.error }}</div>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <td class="thin centeralign">
                        {% if setup.schema %}
                            <span class="success" data-icon="check" aria-label="Complete"></span>
                        {% elseif setup.connection %}
                            <span class="error" data-icon="error" aria-label="Required"></span>
                        {% else %}
                            <span class="warning" data-icon="alert" aria-label="Pending"></span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ cpUrl('ai-search/settings') }}">Initialize the vector schema</a>
                        {% if setup.connection and not setup.schema %}
                            <div class="light smalltext">The vectors table was not found. Run the setup SQL from the Database settings tab.</div>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <td class="thin centeralign">
                        {% if setup.openaiKey %}
                            <span class="success" data-icon="check" aria-label="Complete"></span>
                        {% else %}
                            <span class="error" data-icon="error" aria-label="Required"></span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ cpUrl('ai-search/settings') }}">Add your OpenAI API key</a>
                        {% if not setup.openaiKey %}
                            <div class="light smalltext">Required to generate embeddings during indexing.</div>
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>
    {% endif %}

    <div id="reindex-progress" style="display: none; margin-top: 16px;">
        <div class="pane">
            <p><strong>Syncing in progress...</strong></p>
            <p class="light">Entries indexed: <span id="progress-entries">0</span> | Chunks: <span id="progress-chunks">0</span> | Queue remaining: <span id="progress-queue">0</span></p>
        </div>
    </div>

    <hr>

    <h2>Sync Search Index</h2>
    <p class="light">This will re-index all entries and remove stale vectors. Existing search data remains available throughout the process.</p>

    {% if setup.ready %}
        <p class="warning with-icon">Every entry will be re-indexed, which uses your OpenAI API quota.</p>
    {% else %}
        <p class="light">Complete the steps above to enable syncing.</p>
    {% endif %}

    <form method="post" id="reindex-form">
        {{ csrfInput() }}
        {{ actionInput('ai-search/data-sync/wipe-and-reindex') }}

        <div class="buttons">
            <button type="submit"
                    class="btn submit"
                    id="reindex-btn"
                    {% if not setup.ready %}disabled title="Complete the setup steps above before syncing"{% endif %}
                    onclick="return confirm('Are you sure you want to sync the entire search index? Every entry will be re-indexed.')">
                Sync Entire Index
            </button>
        </div>
    </form>
{% endblock %}

{% if setup.ready %}
{% js %}
(function() {
    function startPolling() {
        var progress = document.getElementById('reindex-progress');
        var btn = document.getElementById('reindex-btn');
        if (progress) progress.style.display = 'block';
        if (btn) btn.disabled = true;

        var peakEntries = 0;
        var peakChunks = 0;

        var interval = setInterval(function() {
            Craft.sendActionRequest('POST', 'ai-search/data-sync/get-stats')
                .then(function(response) {
                    var data = response.data;
                    if (!data.success) return;

                    var entries = document.getElementById('progress-entries');
                    var chunks = document.getElementById('progress-chunks');
                    var queue = document.getElementById('progress-queue');
                    var statEntries = document.getElementById('stat-entries');
                    var statChunks = document.getElementById('stat-chunks');

                    if (data.queueRemaining === 0) {
                        // Show final actual counts on completion
                        clearInterval(interval);
                        if (entries) entries.textContent = data.entryCount.toLocaleString();
                        if (chunks) chunks.textContent = data.chunkCount.toLocaleString();
                        if (statEntries) statEntries.textContent = data.entryCount.toLocaleString();
                        if (statChunks) statChunks.textContent = data.chunkCount.toLocaleString();
                        var progress = document.getElementById('reindex-progress');
                        if (progress) {
                            progress.innerHTML = '<div class="pane"><p><strong>Sync complete.</strong></p></div>';
                        }
                        if (btn) btn.disabled = false;
                        return;
                    }

                    // Only show increasing counts to avoid flickering from delete-then-reinsert
                    peakEntries = Math.max(peakEntries, data.entryCount);
                    peakChunks = Math.max(peakChunks, data.chunkCount);

                    if (entries) entries.textContent = peakEntries.toLocaleString();
                    if (chunks) chunks.textContent = peakChunks.toLocaleString();
                    if (queue) queue.textContent = data.queueRemaining.toLocaleString();
                    if (statEntries) statEntries.textContent = peakEntries.toLocaleString();
                    if (statChunks) statChunks.textContent = peakChunks.toLocaleString();
                })
                .catch(function() {});
        }, 3000);
    }

    // Start polling if sync was just triggered or if there are queued jobs
    {% if syncStarted %}
        startPolling();
    {% else %}
        Craft.sendActionRequest('POST', 'ai-search/data-sync/get-stats')
            .then(function(response) {
                if (response.data.success && response.data.queueRemaining > 0) {
                    startPolling();
                }
            })
            .catch(function() {});
    {% endif %}
})();
{% endjs %}
{% endif %}
