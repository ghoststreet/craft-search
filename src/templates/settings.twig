{% extends "_layouts/cp" %}

{% set title = 'Settings' %}
{% set fullPageForm = true %}

{% set tabs = {
    'tab-api': { label: 'API', url: '#tab-api' },
    'tab-database': { label: 'Database', url: '#tab-database' },
    'tab-hybrid-search': { label: 'Hybrid Search', url: '#tab-hybrid-search' },
    'tab-rag-search': { label: 'RAG Search', url: '#tab-rag-search' },
    'tab-security': { label: 'Security & Limits', url: '#tab-security' },
    'tab-advanced': { label: 'Advanced', url: '#tab-advanced' },
} %}

{% import '_includes/forms.twig' as forms %}

{% block content %}
    <input type="hidden" name="action" value="ai-search/settings/save">
    {{ redirectInput('ai-search/settings') }}

        {# ── API Tab ── #}
        <div id="tab-api">
            <h2>OpenAI Configuration</h2>
            <p class="light">Connect to OpenAI to enable AI-powered search features. Your API key is used to generate embeddings for your content and power intelligent search.</p>

            {% namespace 'settings' %}
                {{ forms.autosuggestField({
                    label: 'API Key',
                    instructions: 'Your OpenAI API key. You can find this in your <a href="https://platform.openai.com/api-keys" target="_blank">OpenAI dashboard</a>. We recommend storing it in an environment variable for security.',
                    id: 'openaiApiKey',
                    name: 'openaiApiKey',
                    value: settings.openaiApiKey,
                    suggestEnvVars: true,
                    required: true,
                    errors: settings.getErrors('openaiApiKey'),
                }) }}
            {% endnamespace %}

            <div class="buttons" style="margin-bottom: 24px;">
                <button type="button" class="btn" id="test-api-key-btn">Test API Key</button>
                <span id="test-api-key-result" style="margin-left: 8px;"></span>
            </div>

            <hr>

            <h2>API Authentication</h2>
            <p class="light">Protect your search endpoints with a token. When set, all API requests must include the token via <code>Authorization: Bearer &lt;token&gt;</code> header or <code>?token=</code> query parameter. Leave empty to allow unauthenticated access.</p>

            {% namespace 'settings' %}
                {{ forms.autosuggestField({
                    label: 'API Token',
                    instructions: 'A secret token to authenticate API requests. We recommend storing it in an environment variable.',
                    id: 'apiToken',
                    name: 'apiToken',
                    value: settings.apiToken,
                    suggestEnvVars: true,
                    errors: settings.getErrors('apiToken'),
                }) }}
            {% endnamespace %}
        </div>

        {# ── Database Tab ── #}
        <div id="tab-database" class="hidden">
            <h2>Vector Database Connection</h2>
            <p class="light">Connect to a PostgreSQL database with the pgvector extension to store your searchable content. We recommend <a href="https://supabase.com" target="_blank">Supabase</a> for easy setup.</p>

            <p><strong>Setup Requirements</strong></p>
            <p class="light">
                <strong>The plugin does not create or modify the schema.</strong> You must create the vectors table, indexes, and a least-privilege role yourself before configuring this page. See the <a href="https://github.com/ghost-street/craft-ai-search#database-setup-required-admin-owned" target="_blank">Database Setup section in the README</a> for the SQL snippet.<br><br>
                Use the dedicated <code>craft_aisearch</code> role here — never the project owner or Supabase service-role credentials.
            </p>

            <hr>

            {% namespace 'settings' %}
            {{ forms.autosuggestField({
                label: 'Host',
                instructions: 'Your database server address. For Supabase, this looks like: <code>db.xxxxxxxxxxxx.supabase.co</code>. You can also paste a full connection URL here (e.g., <code>postgresql://user:pass@host:port/db</code>).',
                id: 'postgresqlHost',
                name: 'postgresqlHost',
                value: settings.postgresqlHost,
                suggestEnvVars: true,
                placeholder: 'db.xxxx.supabase.co or $SUPABASE_DB_HOST',
                errors: settings.getErrors('postgresqlHost'),
            }) }}

            {{ forms.autosuggestField({
                label: 'Port',
                instructions: 'Usually <code>5432</code> for direct connections. Supabase pooled connections use <code>6543</code>.',
                id: 'postgresqlPort',
                name: 'postgresqlPort',
                value: settings.postgresqlPort,
                suggestEnvVars: true,
                placeholder: '5432',
                errors: settings.getErrors('postgresqlPort'),
            }) }}

            {{ forms.autosuggestField({
                label: 'Database Name',
                instructions: 'The name of your database. For Supabase, this is usually <code>postgres</code>.',
                id: 'postgresqlDatabase',
                name: 'postgresqlDatabase',
                value: settings.postgresqlDatabase,
                suggestEnvVars: true,
                placeholder: 'postgres',
                errors: settings.getErrors('postgresqlDatabase'),
            }) }}

            {{ forms.autosuggestField({
                label: 'Username',
                instructions: 'Your database username. For Supabase, this is usually <code>postgres</code>.',
                id: 'postgresqlUser',
                name: 'postgresqlUser',
                value: settings.postgresqlUser,
                suggestEnvVars: true,
                placeholder: 'postgres',
                errors: settings.getErrors('postgresqlUser'),
            }) }}

            {{ forms.autosuggestField({
                label: 'Password',
                instructions: 'Your database password. We strongly recommend storing this in an environment variable.',
                id: 'postgresqlPassword',
                name: 'postgresqlPassword',
                value: settings.postgresqlPassword,
                suggestEnvVars: true,
                placeholder: '$SUPABASE_DB_PASSWORD',
                errors: settings.getErrors('postgresqlPassword'),
            }) }}

            {{ forms.selectField({
                label: 'SSL Mode',
                instructions: 'How to secure the database connection. <strong>Disable / Allow / Prefer are rejected at connect time for any non-localhost host.</strong>',
                id: 'postgresqlSslMode',
                name: 'postgresqlSslMode',
                value: settings.postgresqlSslMode,
                options: [
                    { label: 'Disable - localhost only', value: 'disable' },
                    { label: 'Allow - localhost only', value: 'allow' },
                    { label: 'Prefer - localhost only', value: 'prefer' },
                    { label: 'Require (Recommended) - Always use encryption', value: 'require' },
                    { label: 'Verify CA - Verify server certificate', value: 'verify-ca' },
                    { label: 'Verify Full - Verify certificate and hostname', value: 'verify-full' },
                ],
                required: true,
                errors: settings.getErrors('postgresqlSslMode'),
            }) }}

            {{ forms.textField({
                label: 'Vectors Schema Name',
                instructions: 'Postgres schema where your vectors table lives. Validated as a strict identifier (letters, digits, underscores, ≤63 chars).',
                id: 'vectorsSchemaName',
                name: 'vectorsSchemaName',
                value: settings.vectorsSchemaName,
                placeholder: 'public',
                required: true,
                errors: settings.getErrors('vectorsSchemaName'),
            }) }}

            {{ forms.textField({
                label: 'Vectors Table Name',
                instructions: 'The name of the table you created in the README setup SQL. Must already exist — the plugin will not create it.',
                id: 'vectorsTableName',
                name: 'vectorsTableName',
                value: settings.vectorsTableName,
                placeholder: 'aisearch_vectors',
                required: true,
                errors: settings.getErrors('vectorsTableName'),
            }) }}
            {% endnamespace %}

            <div class="buttons">
                <button type="button" class="btn" id="test-db-btn">Test Connection</button>
                <span id="test-db-result" style="margin-left: 8px;"></span>
            </div>
        </div>

        {# ── Hybrid Search Tab ── #}
        <div id="tab-hybrid-search" class="hidden">
            <h2>Embedding Model</h2>
            <p class="light">Choose the AI model for generating content embeddings. Changing this requires re-indexing your content.</p>

            {% namespace 'settings' %}
            {{ forms.selectField({
                label: 'Embedding Model',
                instructions: 'The OpenAI model used to convert content into searchable embeddings.',
                id: 'hybridEmbeddingModel',
                name: 'hybridEmbeddingModel',
                value: settings.hybridEmbeddingModel,
                options: [
                    { label: 'text-embedding-3-small (Recommended)', value: 'text-embedding-3-small' },
                    { label: 'text-embedding-3-large', value: 'text-embedding-3-large' },
                ],
                required: true,
                errors: settings.getErrors('hybridEmbeddingModel'),
            }) }}

            {{ forms.selectField({
                label: 'Vector Dimensions',
                instructions: 'Number of dimensions for embedding vectors. Lower dimensions are faster and cheaper. <strong>Changing this requires a full reindex.</strong>',
                id: 'vectorDimensions',
                name: 'vectorDimensions',
                value: settings.vectorDimensions,
                options: [
                    { label: '512 (fastest, lowest quality)', value: 512 },
                    { label: '1024 (balanced)', value: 1024 },
                    { label: '1536 (default)', value: 1536 },
                    { label: '3072 (text-embedding-3-large only)', value: 3072 },
                ],
                errors: settings.getErrors('vectorDimensions'),
            }) }}

            <hr>

            <h2>Search Tuning</h2>
            <p class="light">Fine-tune how search results are ranked. These settings balance traditional keyword matching with AI-powered semantic understanding.</p>

            {{ forms.textField({
                label: 'Final Result Threshold',
                instructions: 'Minimum combined score for a result to appear in final output. Higher values (0.85-0.95) show only very relevant results. Lower values (0.7-0.8) show more results but may include less relevant content. Range: 0-1, default: 0.9',
                id: 'minimumSimilarityThreshold',
                name: 'minimumSimilarityThreshold',
                value: settings.minimumSimilarityThreshold,
                type: 'number',
                step: '0.01',
                min: '0',
                max: '1',
                placeholder: '0.90',
                required: true,
                errors: settings.getErrors('minimumSimilarityThreshold'),
            }) }}

            <hr>

            <h2>Result Ranking</h2>
            <p class="light">Control how keyword matches and AI understanding are combined to rank results. The weights should add up to 1.0 for best results.</p>

            {{ forms.textField({
                label: 'AI Understanding Weight',
                instructions: 'How much to favor results that match the meaning of the search, even without exact keywords. Higher values prioritize semantic matches. Range: 0-1, default: 0.3',
                id: 'rrfSemanticWeight',
                name: 'rrfSemanticWeight',
                value: settings.rrfSemanticWeight,
                type: 'number',
                step: '0.1',
                min: '0',
                max: '1',
                placeholder: '0.3',
                required: true,
                errors: settings.getErrors('rrfSemanticWeight'),
            }) }}

            {{ forms.textField({
                label: 'Keyword Match Weight',
                instructions: 'How much to favor results that contain the exact search words. Higher values prioritize traditional keyword matching. Range: 0-1, default: 0.7',
                id: 'rrfBm25Weight',
                name: 'rrfBm25Weight',
                value: settings.rrfBm25Weight,
                type: 'number',
                step: '0.1',
                min: '0',
                max: '1',
                placeholder: '0.7',
                required: true,
                errors: settings.getErrors('rrfBm25Weight'),
            }) }}

            {{ forms.textField({
                label: 'Ranking Smoothness',
                instructions: 'Technical parameter (RRF K constant) that controls how ranking scores decrease. Higher values give more weight to lower-ranked results. Most users can leave this at the default. Range: 1-1000, default: 60',
                id: 'rrfK',
                name: 'rrfK',
                value: settings.rrfK,
                type: 'number',
                min: '1',
                max: '1000',
                placeholder: '60',
                required: true,
                errors: settings.getErrors('rrfK'),
            }) }}
            {% endnamespace %}
        </div>

        {# ── RAG Search Tab ── #}
        <div id="tab-rag-search" class="hidden">
            <h2>AI Search</h2>
            <p class="light">Configure the AI-powered search that finds relevant content and generates intelligent summaries.</p>

            {% namespace 'settings' %}
            {{ forms.selectField({
                label: 'Embedding Model',
                instructions: 'The OpenAI model used to convert queries into searchable embeddings.',
                id: 'ragEmbeddingModel',
                name: 'ragEmbeddingModel',
                value: settings.ragEmbeddingModel,
                options: [
                    { label: 'text-embedding-3-small (Recommended)', value: 'text-embedding-3-small' },
                    { label: 'text-embedding-3-large', value: 'text-embedding-3-large' },
                ],
                required: true,
                errors: settings.getErrors('ragEmbeddingModel'),
            }) }}

            {{ forms.selectField({
                label: 'Reasoning Model',
                instructions: 'Choose which OpenAI model powers the search assistant. Faster models cost less but may provide simpler answers.',
                id: 'ragModel',
                name: 'ragModel',
                value: settings.ragModel,
                options: [
                    { label: 'gpt-5.4-nano', value: 'gpt-5.4-nano' },
                ],
                required: true,
                errors: settings.getErrors('ragModel'),
            }) }}

            <hr>

            <h2>Custom Instructions</h2>
            <p class="light">Add custom instructions that will be included with every search request. Use this to customize how the AI responds, what tone to use, or any specific guidelines for your content.</p>

            {{ forms.textareaField({
                label: 'Custom Prompt',
                instructions: 'Optional instructions appended to the system prompt. Leave empty to use default behavior.',
                id: 'ragCustomPrompt',
                name: 'ragCustomPrompt',
                value: settings.ragCustomPrompt,
                rows: 6,
                placeholder: 'Example: Always respond in a friendly, conversational tone. When discussing products, highlight their key benefits.',
                errors: settings.getErrors('ragCustomPrompt'),
            }) }}
            {% endnamespace %}
        </div>

        {# ── Security & Limits Tab ── #}
        <div id="tab-security" class="hidden">
            <h2>Origin Allowlist</h2>
            <p class="light">Browser requests must come from this Craft site by default. Add extra origins here (comma-separated, e.g. <code>https://app.example.com,https://www.example.com</code>) for headless front-ends. CSRF is always required regardless of this setting.</p>

            {% namespace 'settings' %}
            {{ forms.autosuggestField({
                label: 'Allowed Origins',
                instructions: 'Comma-separated list of additional allowed origins. Leave empty for same-origin only.',
                id: 'allowedOrigins',
                name: 'allowedOrigins',
                value: settings.allowedOrigins,
                suggestEnvVars: true,
                placeholder: 'https://app.example.com',
                errors: settings.getErrors('allowedOrigins'),
            }) }}

            <hr>

            <h2>Per-IP Rate Limits</h2>
            <p class="light">Token-bucket caps applied to every visitor. RAG limits are stricter because LLM calls are far more expensive than embedding/search.</p>

            {{ forms.textField({
                label: 'Search requests per minute (per IP)',
                instructions: 'Applies to /api/hybrid-search and /api/craft-search.',
                id: 'rateLimitSearchPerMinute', name: 'rateLimitSearchPerMinute',
                value: settings.rateLimitSearchPerMinute, type: 'number', min: '1', max: '100000',
                required: true, errors: settings.getErrors('rateLimitSearchPerMinute'),
            }) }}
            {{ forms.textField({
                label: 'Search requests per hour (per IP)',
                id: 'rateLimitSearchPerHour', name: 'rateLimitSearchPerHour',
                value: settings.rateLimitSearchPerHour, type: 'number', min: '1', max: '100000',
                required: true, errors: settings.getErrors('rateLimitSearchPerHour'),
            }) }}
            {{ forms.textField({
                label: 'RAG requests per minute (per IP)',
                instructions: 'Applies to /api/rag-search and /api/rag-search/stream.',
                id: 'rateLimitRagPerMinute', name: 'rateLimitRagPerMinute',
                value: settings.rateLimitRagPerMinute, type: 'number', min: '1', max: '100000',
                required: true, errors: settings.getErrors('rateLimitRagPerMinute'),
            }) }}
            {{ forms.textField({
                label: 'RAG requests per hour (per IP)',
                id: 'rateLimitRagPerHour', name: 'rateLimitRagPerHour',
                value: settings.rateLimitRagPerHour, type: 'number', min: '1', max: '100000',
                required: true, errors: settings.getErrors('rateLimitRagPerHour'),
            }) }}

            <hr>

            <h2>RAG Concurrency Caps</h2>
            <p class="light">Bounds the number of simultaneous in-flight RAG requests so a slow OpenAI endpoint can't pin all your Craft workers.</p>

            {{ forms.textField({
                label: 'Max concurrent RAG per IP',
                id: 'ragConcurrencyPerIp', name: 'ragConcurrencyPerIp',
                value: settings.ragConcurrencyPerIp, type: 'number', min: '1', max: '100000',
                required: true, errors: settings.getErrors('ragConcurrencyPerIp'),
            }) }}
            {{ forms.textField({
                label: 'Max concurrent RAG (global)',
                id: 'ragConcurrencyGlobal', name: 'ragConcurrencyGlobal',
                value: settings.ragConcurrencyGlobal, type: 'number', min: '1', max: '100000',
                required: true, errors: settings.getErrors('ragConcurrencyGlobal'),
            }) }}

            <hr>

            <h2>Daily Cost Budgets (USD)</h2>
            <p class="light">When the budget is reached, RAG requests return 503 with <code>Retry-After</code>. Budgets reset every 24 hours.</p>

            {{ forms.textField({
                label: 'Per-IP daily cap (USD)',
                id: 'costBudgetDailyPerIp', name: 'costBudgetDailyPerIp',
                value: settings.costBudgetDailyPerIp, type: 'number', step: '0.01', min: '0',
                errors: settings.getErrors('costBudgetDailyPerIp'),
            }) }}
            {{ forms.textField({
                label: 'Global daily cap (USD)',
                id: 'costBudgetDailyGlobal', name: 'costBudgetDailyGlobal',
                value: settings.costBudgetDailyGlobal, type: 'number', step: '0.01', min: '0',
                errors: settings.getErrors('costBudgetDailyGlobal'),
            }) }}

            <hr>

            <h2>Prompt &amp; Error Hygiene</h2>

            {{ forms.textField({
                label: 'Max prompt tokens',
                instructions: 'Hard cap on the assembled RAG prompt (system + user + context). The context block list is truncated to fit. Range: 500–100000.',
                id: 'maxPromptTokens', name: 'maxPromptTokens',
                value: settings.maxPromptTokens, type: 'number', min: '500', max: '100000',
                required: true, errors: settings.getErrors('maxPromptTokens'),
            }) }}

            {{ forms.lightswitchField({
                label: 'Expose stack traces in API errors',
                instructions: 'Off by default. devMode alone is not enough; this is a separate switch so production never leaks file paths via API responses.',
                id: 'exposeStackTraces', name: 'exposeStackTraces',
                on: settings.exposeStackTraces,
                errors: settings.getErrors('exposeStackTraces'),
            }) }}
            {% endnamespace %}
        </div>

        {# ── Advanced Tab ── #}
        <div id="tab-advanced" class="hidden">
            <h2>Indexing Filter</h2>
            <p class="light">Choose which sections to index. Leave empty to index all sections with URLs.</p>

            {% namespace 'settings' %}
            {% set allSections = craft.app.entries.allSections() %}
            {% set sectionOptions = [] %}
            {% for section in allSections %}
                {% set sectionOptions = sectionOptions|merge([{ label: section.name, value: section.handle }]) %}
            {% endfor %}

            {{ forms.checkboxSelectField({
                label: 'Indexable Sections',
                instructions: 'Select which sections should be indexed for search. If none are selected, all sections with URLs will be indexed.',
                id: 'indexableSections',
                name: 'indexableSections',
                values: settings.indexableSections,
                options: sectionOptions,
                errors: settings.getErrors('indexableSections'),
            }) }}

            <hr>

            <h2>Display Settings</h2>

            {{ forms.textField({
                label: 'Result Preview Length',
                instructions: 'Number of characters shown in search result previews. Range: 50-500, default: 200',
                id: 'excerptLength',
                name: 'excerptLength',
                value: settings.excerptLength,
                type: 'number',
                min: '50',
                max: '500',
                placeholder: '200',
                required: true,
                errors: settings.getErrors('excerptLength'),
            }) }}

            <hr>

            <h2>Content Chunking</h2>
            <p class="light">Control how your content is split into searchable chunks. Smaller chunks provide more precise search results but may lose context. Larger chunks preserve context but may be less precise.</p>

            {{ forms.textField({
                label: 'Minimum Chunk Size',
                instructions: 'Smallest content chunk size (in tokens) for indexing. Chunks smaller than this will be merged with adjacent content. Range: 10-500, default: 100',
                id: 'minChunkTokens',
                name: 'minChunkTokens',
                value: settings.minChunkTokens,
                type: 'number',
                min: '10',
                max: '500',
                placeholder: '100',
                required: true,
                errors: settings.getErrors('minChunkTokens'),
            }) }}

            {{ forms.textField({
                label: 'Target Chunk Size',
                instructions: 'Ideal content chunk size for best search accuracy. The system aims to create chunks around this size. Range: 100-1000, default: 400',
                id: 'targetChunkTokens',
                name: 'targetChunkTokens',
                value: settings.targetChunkTokens,
                type: 'number',
                min: '100',
                max: '1000',
                placeholder: '400',
                required: true,
                errors: settings.getErrors('targetChunkTokens'),
            }) }}

            {{ forms.textField({
                label: 'Maximum Chunk Size',
                instructions: 'Largest chunk size before forcing a split. Chunks larger than this will be split at sentence boundaries. Range: 200-2000, default: 600',
                id: 'maxChunkTokens',
                name: 'maxChunkTokens',
                value: settings.maxChunkTokens,
                type: 'number',
                min: '200',
                max: '2000',
                placeholder: '600',
                required: true,
                errors: settings.getErrors('maxChunkTokens'),
            }) }}

            {{ forms.textField({
                label: 'Chunk Overlap',
                instructions: 'Token overlap between adjacent chunks. Overlap helps preserve context across chunk boundaries. Range: 0-200, default: 40',
                id: 'overlapTokens',
                name: 'overlapTokens',
                value: settings.overlapTokens,
                type: 'number',
                min: '0',
                max: '200',
                placeholder: '40',
                required: true,
                errors: settings.getErrors('overlapTokens'),
            }) }}

            {{ forms.textField({
                label: 'Chunking Threshold',
                instructions: 'Content smaller than this (in tokens) will not be split into chunks. Range: 100-1000, default: 500',
                id: 'chunkThresholdTokens',
                name: 'chunkThresholdTokens',
                value: settings.chunkThresholdTokens,
                type: 'number',
                min: '100',
                max: '1000',
                placeholder: '500',
                required: true,
                errors: settings.getErrors('chunkThresholdTokens'),
            }) }}

            <hr>

            <h2>Cache Settings</h2>

            {{ forms.textField({
                label: 'Embedding Cache Duration',
                instructions: 'How long embeddings are cached (in seconds). Longer cache times reduce API costs but delay updates. Range: 0-2592000, default: 604800 (7 days)',
                id: 'embeddingCacheTtl',
                name: 'embeddingCacheTtl',
                value: settings.embeddingCacheTtl,
                type: 'number',
                min: '0',
                max: '2592000',
                placeholder: '604800',
                required: true,
                errors: settings.getErrors('embeddingCacheTtl'),
            }) }}

            <hr>

            <h2>Hybrid Search Tuning</h2>

            {{ forms.textField({
                label: 'Semantic Pre-filter Threshold',
                instructions: 'Minimum cosine similarity for a result to enter the hybrid ranking pipeline. This is applied before combining with keyword scores. Lower values allow more candidates into the ranking stage. Range: 0-1, default: 0.5',
                id: 'minSemanticThreshold',
                name: 'minSemanticThreshold',
                value: settings.minSemanticThreshold,
                type: 'number',
                step: '0.1',
                min: '0',
                max: '1',
                placeholder: '0.5',
                required: true,
                errors: settings.getErrors('minSemanticThreshold'),
            }) }}

            {{ forms.textField({
                label: 'Single-Signal Penalty',
                instructions: 'Score reduction for results that appear in only one search signal (either semantic OR keyword, but not both). Lower values penalize single-signal results more. Range: 0-1, default: 0.5',
                id: 'singleSignalPenalty',
                name: 'singleSignalPenalty',
                value: settings.singleSignalPenalty,
                type: 'number',
                step: '0.1',
                min: '0',
                max: '1',
                placeholder: '0.5',
                required: true,
                errors: settings.getErrors('singleSignalPenalty'),
            }) }}

            {{ forms.textField({
                label: 'Maximum Semantic Results',
                instructions: 'Maximum number of semantic results to retrieve before ranking. Higher values may improve result quality but increase processing time. Range: 10-500, default: 100',
                id: 'maxSemanticResults',
                name: 'maxSemanticResults',
                value: settings.maxSemanticResults,
                type: 'number',
                min: '10',
                max: '500',
                placeholder: '100',
                required: true,
                errors: settings.getErrors('maxSemanticResults'),
            }) }}

            <hr>

            <h2>Search History</h2>
            <p class="light">Track every search to monitor token usage, costs, and performance. Result content is deleted after the retention period, but token and cost statistics are kept permanently for the dashboard.</p>

            {{ forms.lightswitchField({
                label: 'Enable search history tracking',
                instructions: 'When enabled, every semantic and RAG search is recorded with token usage, cost, and timing.',
                id: 'historyEnabled',
                name: 'historyEnabled',
                on: settings.historyEnabled,
                errors: settings.getErrors('historyEnabled'),
            }) }}

            {{ forms.textField({
                label: 'History retention (days)',
                instructions: 'Number of days to keep stored queries and result data before pruning. Token/cost statistics are kept permanently. Range: 1-365, default: 30',
                id: 'historyRetentionDays',
                name: 'historyRetentionDays',
                value: settings.historyRetentionDays,
                type: 'number',
                min: '1',
                max: '365',
                placeholder: '30',
                required: true,
                errors: settings.getErrors('historyRetentionDays'),
            }) }}
            {% endnamespace %}
        </div>

{% endblock %}

{% js %}
(function() {
    // Test Database Connection
    var dbBtn = document.getElementById('test-db-btn');
    if (dbBtn) {
        dbBtn.addEventListener('click', function() {
            var result = document.getElementById('test-db-result');
            result.textContent = 'Testing...';
            result.style.color = '';
            Craft.sendActionRequest('POST', 'ai-search/settings/test-database-connection')
                .then(function(response) {
                    result.textContent = response.data.message;
                    result.style.color = response.data.success ? 'green' : 'red';
                })
                .catch(function(error) {
                    result.textContent = error.response?.data?.message || 'Connection failed';
                    result.style.color = 'red';
                });
        });
    }

    // Test API Key
    var apiBtn = document.getElementById('test-api-key-btn');
    if (apiBtn) {
        apiBtn.addEventListener('click', function() {
            var result = document.getElementById('test-api-key-result');
            result.textContent = 'Testing...';
            result.style.color = '';
            Craft.sendActionRequest('POST', 'ai-search/settings/test-api-key')
                .then(function(response) {
                    result.textContent = response.data.message;
                    result.style.color = response.data.success ? 'green' : 'red';
                })
                .catch(function(error) {
                    result.textContent = error.response?.data?.message || 'API key test failed';
                    result.style.color = 'red';
                });
        });
    }
})();
{% endjs %}
