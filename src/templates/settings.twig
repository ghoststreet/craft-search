{% extends "_layouts/cp" %}

{% set title = 'Settings' %}
{% set fullPageForm = true %}

{% set tabs = {
    'tab-connections':   { label: 'Connections',   url: '#tab-connections',   class: settings.errorsForTab('tab-connections')   ? 'error' : '' },
    'tab-indexing':      { label: 'Indexing',      url: '#tab-indexing',      class: settings.errorsForTab('tab-indexing')      ? 'error' : '' },
    'tab-hybrid-search': { label: 'Hybrid Search', url: '#tab-hybrid-search', class: settings.errorsForTab('tab-hybrid-search') ? 'error' : '' },
    'tab-ai-answers':    { label: 'AI Answers',    url: '#tab-ai-answers',    class: settings.errorsForTab('tab-ai-answers')    ? 'error' : '' },
    'tab-operations':    { label: 'Operations',    url: '#tab-operations',    class: settings.errorsForTab('tab-operations')    ? 'error' : '' },
} %}

{% block content %}
    {{ actionInput('ai-search/settings/save') }}
    {{ redirectInput('ai-search/settings') }}

    <div id="tab-connections">
        {% include 'ai-search/_settings/_connections' %}
    </div>

    <div id="tab-indexing" class="hidden">
        {% include 'ai-search/_settings/_indexing' %}
    </div>

    <div id="tab-hybrid-search" class="hidden">
        {% include 'ai-search/_settings/_hybrid_search' %}
    </div>

    <div id="tab-ai-answers" class="hidden">
        {% include 'ai-search/_settings/_ai_answers' %}
    </div>

    <div id="tab-operations" class="hidden">
        {% include 'ai-search/_settings/_operations' %}
    </div>
{% endblock %}

{% js %}
(function() {
    var DOM = window.CraftSearch.core.DOM;

    var errors = window.CraftSearch.core.errors;

    function wireTest(controlName, resultName, action, successMessage) {
        var btn = DOM.findControl(controlName);
        if (!btn) return;
        btn.addEventListener('click', function() {
            var result = DOM.find(resultName);
            result.textContent = 'Testing…';
            result.style.color = '';
            Craft.sendActionRequest('POST', action)
                .then(function(response) {
                    var data = response.data || {};
                    if (data.success) {
                        result.textContent = successMessage;
                        result.style.color = 'green';
                    } else {
                        result.textContent = errors.messageFor(data);
                        result.style.color = 'red';
                    }
                })
                .catch(function(error) {
                    var body = (error && error.response && error.response.data) || {};
                    result.textContent = errors.messageFor(body);
                    result.style.color = 'red';
                });
        });
    }

    wireTest('test-db', 'test-db-result', 'ai-search/settings/test-database-connection', 'Connected successfully.');
    wireTest('test-api-key', 'test-api-key-result', 'ai-search/settings/test-api-key', 'API key is valid.');

    // Live "reindex required" warning when the hybrid embedding model is changed.
    var hybridSelect = document.getElementById('settings-hybridEmbeddingModel');
    var hybridWarning = DOM.find('hybrid-embedding-warning');
    if (hybridSelect && hybridWarning) {
        var originalHybrid = hybridSelect.value;
        hybridSelect.addEventListener('change', function() {
            hybridWarning.classList.toggle('hidden', hybridSelect.value === originalHybrid);
        });
    }

    // Live sum hint under the BM25/semantic weight pair.
    var semantic = document.getElementById('settings-rrfSemanticWeight');
    var bm25 = document.getElementById('settings-rrfBm25Weight');
    var sumHint = DOM.find('weight-sum-hint');
    if (semantic && bm25 && sumHint) {
        function refreshSum() {
            var s = parseFloat(semantic.value) || 0;
            var k = parseFloat(bm25.value) || 0;
            var total = Math.round((s + k) * 100) / 100;
            var ok = Math.abs(total - 1) < 0.001;
            sumHint.textContent = 'Weights sum: ' + total.toFixed(2) + (ok ? ' ✓' : ' — should equal 1.00');
            sumHint.style.color = ok ? 'green' : '#cf1124';
        }
        semantic.addEventListener('input', refreshSum);
        bm25.addEventListener('input', refreshSum);
        refreshSum();
    }
})();
{% endjs %}
