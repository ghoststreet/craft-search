{% extends "_layouts/cp" %}

{% set title = 'Index' %}
{% set selectedSubnavItem = 'index' %}

{% block content %}
    <ul class="aisearch-tabs">
        <li><a href="{{ cpUrl('ai-search/index', { tab: 'overview' }) }}"{% if tab == 'overview' %} class="sel"{% endif %}>Overview &amp; sync</a></li>
        <li><a href="{{ cpUrl('ai-search/index', { tab: 'entries' }) }}"{% if tab == 'entries' %} class="sel"{% endif %}>Entries</a></li>
        <li><a href="{{ cpUrl('ai-search/index', { tab: 'coverage' }) }}"{% if tab == 'coverage' %} class="sel"{% endif %}>Per-site coverage</a></li>
    </ul>

    {% if tab == 'overview' %}
        {% if setup.ready %}
            <h2>Index statistics</h2>
            {% include 'ai-search/_partials/index-stats-table' with { stats: stats } only %}
        {% else %}
            <h2>Finish setup</h2>
            <p class="light">Each step links to where it can be fixed.</p>
            <table class="data fullwidth collapsible">
                <tbody>
                    {% set steps = [
                        { done: setup.credentials, label: 'Configure PostgreSQL credentials', hint: setup.credentials ? null : 'Host, database, user, and password are all required.' },
                        { done: setup.connection, label: 'Connect to the vector database', hint: (setup.credentials and not setup.connection) ? setup.error : null },
                        { done: setup.schema, label: 'Initialize the vector schema', hint: (setup.connection and not setup.schema) ? 'The vectors table was not found. Run the setup SQL from the README.' : null },
                        { done: setup.openaiKey, label: 'Add the OpenAI API key', hint: setup.openaiKey ? null : 'Required to generate embeddings during indexing.' },
                    ] %}
                    {% for step in steps %}
                        <tr>
                            <td class="thin centeralign">
                                {% if step.done %}<span class="success" data-icon="check"></span>
                                {% else %}<span class="error" data-icon="error"></span>{% endif %}
                            </td>
                            <td>
                                <a href="{{ cpUrl('ai-search/settings') }}">{{ step.label }}</a>
                                {% if step.hint %}<div class="light smalltext">{{ step.hint }}</div>{% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}

        <div id="reindex-progress" style="display: none; margin-top: 16px;">
            <div class="pane">
                <p><strong>Syncing in progress…</strong></p>
                <p class="light">Entries: <span id="progress-entries">0</span> | Chunks: <span id="progress-chunks">0</span> | Queue: <span id="progress-queue">0</span></p>
            </div>
        </div>

        <hr>

        <h2>Sync entire index</h2>
        <p class="light">Wipes all stored vectors and queues a re-index for every published entry. Search returns empty results until the queue drains.</p>
        {% if setup.ready %}
            <p class="warning with-icon">Every entry will be re-indexed, which uses your OpenAI API quota.</p>
        {% else %}
            <p class="light">Complete the steps above to enable syncing.</p>
        {% endif %}

        <form method="post" id="reindex-form">
            {{ csrfInput() }}
            {{ actionInput('ai-search/index/wipe-and-reindex') }}
            <div class="buttons">
                <button type="submit" class="btn submit" id="reindex-btn"
                        {% if not setup.ready %}disabled{% endif %}
                        onclick="return confirm('Sync the entire search index? Every entry will be re-indexed.')">
                    Sync entire index
                </button>
            </div>
        </form>

    {% elseif tab == 'entries' %}
        {% if error %}
            <blockquote class="note warning"><p><strong>Database error.</strong> {{ error }}</p></blockquote>
        {% endif %}

        {% set counts = result.counts ?? { indexed: 0, stale: 0, 'not-indexed': 0, total: result.total } %}
        {% set totalPages = (result.total / result.pageSize)|round(0, 'ceil') %}

        {% include 'ai-search/_partials/entries-toolbar' with {
            filters: filters,
            sites: sites,
            sections: sections,
            hiddenFields: { tab: 'entries' },
        } only %}

        {% include 'ai-search/_partials/entries-stats' with { counts: counts } only %}

        {% include 'ai-search/_partials/entries-table' with {
            rows: result.rows,
            entryUrlPath: 'ai-search/index/entry',
        } only %}

        {% include 'ai-search/_components/pagination-path' with {
            currentPage: result.page,
            totalPages: totalPages,
            params: filters|merge({ tab: 'entries' }),
            pageLabel: 'Page ' ~ result.page ~ ' of ' ~ totalPages,
        } only %}

    {% elseif tab == 'coverage' %}
        <p class="light">Index coverage per Craft site. Rebuild stale entries from the Overview &amp; sync tab.</p>
        <table class="data fullwidth">
            <thead><tr><th>Site</th><th class="rightalign">Indexed</th><th class="rightalign">Stale</th><th class="rightalign">Not indexed</th><th class="rightalign">Total</th><th class="rightalign">Coverage</th></tr></thead>
            <tbody>
                {% for c in coverage %}
                    {% set pct = c.total > 0 ? (c.indexed / c.total * 100)|round : 0 %}
                    <tr>
                        <td>{{ c.site }}</td>
                        <td class="rightalign">{{ c.indexed }}</td>
                        <td class="rightalign">{% if c.stale > 0 %}<span class="status orange"></span> {{ c.stale }}{% else %}—{% endif %}</td>
                        <td class="rightalign">{% if c.notIndexed > 0 %}<span class="status off"></span> {{ c.notIndexed }}{% else %}—{% endif %}</td>
                        <td class="rightalign">{{ c.total }}</td>
                        <td class="rightalign">{{ pct }}%</td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="centeralign light">No sites configured.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}

{% if tab == 'overview' and setup.ready %}
{% js %}
(function() {
    function startPolling() {
        var progress = document.getElementById('reindex-progress');
        var btn = document.getElementById('reindex-btn');
        if (progress) progress.style.display = 'block';
        if (btn) btn.disabled = true;

        var peakEntries = 0, peakChunks = 0;
        var interval = setInterval(function() {
            Craft.sendActionRequest('POST', 'ai-search/index/get-stats').then(function(response) {
                var data = response.data;
                if (!data.success) return;
                var entries = document.getElementById('progress-entries');
                var chunks = document.getElementById('progress-chunks');
                var queue = document.getElementById('progress-queue');
                var statEntries = document.getElementById('stat-entries');
                var statChunks = document.getElementById('stat-chunks');
                if (data.queueRemaining === 0) {
                    clearInterval(interval);
                    if (entries) entries.textContent = data.entryCount.toLocaleString();
                    if (chunks) chunks.textContent = data.chunkCount.toLocaleString();
                    if (statEntries) statEntries.textContent = data.entryCount.toLocaleString();
                    if (statChunks) statChunks.textContent = data.chunkCount.toLocaleString();
                    progress.innerHTML = '<div class="pane"><p><strong>Sync complete.</strong></p></div>';
                    if (btn) btn.disabled = false;
                    return;
                }
                peakEntries = Math.max(peakEntries, data.entryCount);
                peakChunks = Math.max(peakChunks, data.chunkCount);
                if (entries) entries.textContent = peakEntries.toLocaleString();
                if (chunks) chunks.textContent = peakChunks.toLocaleString();
                if (queue) queue.textContent = data.queueRemaining.toLocaleString();
                if (statEntries) statEntries.textContent = peakEntries.toLocaleString();
                if (statChunks) statChunks.textContent = peakChunks.toLocaleString();
            }).catch(function() {});
        }, 3000);
    }
    {% if syncStarted %}
        startPolling();
    {% else %}
        Craft.sendActionRequest('POST', 'ai-search/index/get-stats').then(function(r) {
            if (r.data.success && r.data.queueRemaining > 0) startPolling();
        }).catch(function() {});
    {% endif %}
})();
{% endjs %}
{% endif %}
