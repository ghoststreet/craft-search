{% extends "_layouts/cp" %}
{% import 'ai-search/_components/filter-fields' as f %}

{% set title = 'Insights' %}
{% set selectedSubnavItem = 'insights' %}

{% set days = filters.days %}
{% set siteId = filters.siteId %}
{% set tabParams = { days: days, siteId: siteId } %}

{% block content %}
    <ul class="pill-tabs">
        <li><a href="{{ cpUrl('ai-search/insights', tabParams|merge({ tab: 'queries' })) }}"{% if tab == 'queries' %} class="sel"{% endif %}>Top queries</a></li>
        <li><a href="{{ cpUrl('ai-search/insights', tabParams|merge({ tab: 'zero-results' })) }}"{% if tab == 'zero-results' %} class="sel"{% endif %}>Zero results</a></li>
        <li><a href="{{ cpUrl('ai-search/insights', tabParams|merge({ tab: 'trending' })) }}"{% if tab == 'trending' %} class="sel"{% endif %}>Trending</a></li>
        <li><a href="{{ cpUrl('ai-search/insights', tabParams|merge({ tab: 'history' })) }}"{% if tab == 'history' %} class="sel"{% endif %}>History log</a></li>
    </ul>

    <form method="get" action="{{ cpUrl('ai-search/insights') }}" class="filter-bar">
        <input type="hidden" name="tab" value="{{ tab }}">
        {{ f.daysSelect(days, 'Time range') }}
        {{ f.sitesSelect(sites, siteId) }}
        {% if tab == 'history' %}
            {{ f.typeSelect(filters.type) }}
            {{ f.errorsOnlyCheckbox(filters.errorsOnly, true) }}
        {% endif %}
        {{ f.submitButton() }}
    </form>

    {% if tab == 'queries' %}
        <table class="data fullwidth">
            <thead><tr><th>Query</th><th class="rightalign">Hits</th><th class="rightalign">0-result</th><th>Last seen</th></tr></thead>
            <tbody>
                {% for k in rows %}
                    <tr>
                        <td>{{ k.query|slice(0, 100) }}{% if k.query|length > 100 %}…{% endif %}</td>
                        <td class="rightalign">{{ k.hits|number_format }}</td>
                        <td class="rightalign">{% if k.zeroHits > 0 %}<span class="light">{{ k.zeroHits }}</span>{% else %}—{% endif %}</td>
                        <td><span class="light">{{ k.lastSeen|date('M j, g:ia') }}</span></td>
                    </tr>
                {% else %}
                    <tr><td colspan="4" class="centeralign light">No queries recorded.</td></tr>
                {% endfor %}
            </tbody>
        </table>

    {% elseif tab == 'zero-results' %}
        <p class="light">Queries that returned no results. These often reveal missing content or overly strict thresholds.</p>
        <table class="data fullwidth">
            <thead><tr><th>Query</th><th class="rightalign">Hits</th><th>Last seen</th></tr></thead>
            <tbody>
                {% for k in rows %}
                    <tr>
                        <td>{{ k.query|slice(0, 100) }}{% if k.query|length > 100 %}…{% endif %}</td>
                        <td class="rightalign">{{ k.hits|number_format }}</td>
                        <td><span class="light">{{ k.lastSeen|date('M j, g:ia') }}</span></td>
                    </tr>
                {% else %}
                    <tr><td colspan="3" class="centeralign light">All searches returned results.</td></tr>
                {% endfor %}
            </tbody>
        </table>

    {% elseif tab == 'trending' %}
        <p class="light">Queries whose frequency rose in the last 7 days vs the prior 7-day window.</p>
        <table class="data fullwidth">
            <thead><tr><th>Query</th><th class="rightalign">Recent</th><th class="rightalign">Prior</th><th class="rightalign">Δ</th></tr></thead>
            <tbody>
                {% for k in rows %}
                    <tr>
                        <td>{{ k.query|slice(0, 100) }}{% if k.query|length > 100 %}…{% endif %}</td>
                        <td class="rightalign">{{ k.recent }}</td>
                        <td class="rightalign">{{ k.prior }}</td>
                        <td class="rightalign">
                            {% if k.growthPct is null %}<span class="status on" title="New"></span> new
                            {% else %}+{{ k.growthPct }}%{% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="4" class="centeralign light">Not enough data to spot trends.</td></tr>
                {% endfor %}
            </tbody>
        </table>

    {% elseif tab == 'history' %}
        <table class="data fullwidth">
            <tbody>
                <tr>
                    <th class="light">Searches</th><td>{{ stats.searches|number_format }}</td>
                    <th class="light">Tokens</th><td>{{ stats.tokens|number_format }}</td>
                    <th class="light">Total cost</th><td>${{ stats.cost|number_format(6) }}</td>
                    <th class="light">Avg duration</th><td>{{ stats.avgDurationMs|number_format }} ms</td>
                    <th class="light">Errors</th><td>{{ stats.errorCount|number_format }}</td>
                </tr>
            </tbody>
        </table>

        {% if currentUser.admin %}
            <form method="post" class="insights-index__clear-form" data-craftsearch-confirm="Permanently delete all stored queries and result data? Token/cost statistics are preserved.">
                {{ csrfInput() }}
                {{ actionInput('ai-search/insights/clear') }}
                <button type="submit" class="btn"{% if detailsCount == 0 %} disabled{% endif %}>Clear history ({{ detailsCount }})</button>
            </form>
        {% endif %}

        {% include 'ai-search/_partials/search-history-table' with {
            items: page.items,
            urlPath: 'ai-search/insights',
            cachedTitle: 'Cached',
        } only %}

        {% include 'ai-search/_components/pagination-cp' with {
            currentPage: page.page,
            totalPages: page.pages,
            path: 'ai-search/insights',
            baseParams: { tab: 'history', days: days, siteId: siteId, type: filters.type, errorsOnly: filters.errorsOnly ? 1 : null },
        } only %}
    {% endif %}
{% endblock %}
