{#
    Slow queries card — queries whose average duration exceeds the threshold (1500ms).

    Params:
        slowQueries  iterable of { query, hits, avgDurationMs, lastSeen }
#}
<div class="pane">
    <h3 class="dash-title">Slow queries</h3>
    <p class="dash-sub light smalltext">Average duration ≥ 1.5s. Inspect for inefficient prompts or oversized context.</p>
    <table class="data fullwidth">
        <thead>
            <tr>
                <th>Query</th>
                <th class="rightalign">Avg</th>
                <th class="rightalign">Hits</th>
                <th>Last seen</th>
            </tr>
        </thead>
        <tbody>
            {% for q in slowQueries %}
                <tr>
                    <td>{{ q.query|slice(0, 80) }}{% if q.query|length > 80 %}…{% endif %}</td>
                    <td class="rightalign">{{ q.avgDurationMs|round|number_format }} ms</td>
                    <td class="rightalign">{{ q.hits|number_format }}</td>
                    <td><span class="light">{{ q.lastSeen|date('M j, g:ia') }}</span></td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="centeralign light">No queries averaging over 1.5s — latency is healthy.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
