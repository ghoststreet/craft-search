{#
    Search Quality tab body — content-editor focused.

    Params: see index.twig pass-through.
#}
{% include 'smart-search/_dashboard/_kpi-quality' with {
    aggregates: aggregates,
    seriesSearches: seriesSearches,
    seriesZero: seriesZero,
    zeroResultRate: zeroResultRate,
    cacheHitRate: cacheHitRate,
    minNRate: minNRate,
    minNDelta: minNDelta,
} only %}

<div class="dashboard__cols">
    <div class="pane">
        <h3 class="dash-title">Top queries ({{ range }}d)</h3>
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>Query</th>
                    <th class="rightalign">Hits</th>
                    <th class="rightalign">Avg results</th>
                </tr>
            </thead>
            <tbody>
                {% for q in topQueries %}
                    <tr>
                        <td>{{ q.query|slice(0, 80) }}{% if q.query|length > 80 %}…{% endif %}</td>
                        <td class="rightalign">{{ q.hits|number_format }}</td>
                        <td class="rightalign"><span class="light">{{ q.avgResults is defined ? q.avgResults|round(1) : '—' }}</span></td>
                    </tr>
                {% else %}
                    <tr><td colspan="3" class="centeralign light">No search activity yet — queries will appear here once the front-end starts hitting the endpoint.</td></tr>
                {% endfor %}
            </tbody>
        </table>
        {% if topQueries|length %}
            <p class="dash-cta"><a class="go" href="{{ cpUrl('smart-search/insights') }}">View all queries</a></p>
        {% endif %}
    </div>

    <div class="pane">
        <h3 class="dash-title">Zero-result queries ({{ range }}d)</h3>
        <p class="dash-sub light smalltext">Queries that returned nothing — usually a content or indexing gap.</p>
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th>Query</th>
                    <th class="rightalign">Times</th>
                </tr>
            </thead>
            <tbody>
                {% for q in zeroResults %}
                    <tr>
                        <td>{{ q.query|slice(0, 80) }}{% if q.query|length > 80 %}…{% endif %}</td>
                        <td class="rightalign">{{ q.hits|number_format }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="2" class="centeralign light">
                        {%- if aggregates.searches == 0 -%}
                            No search activity yet.
                        {%- else -%}
                            No zero-result queries — every search returned something.
                        {%- endif -%}
                    </td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% include 'smart-search/_dashboard/_trending-queries' with { trendingQueries: trendingQueries } only %}

{% include 'smart-search/_dashboard/_recommendations' with { recommendations: recommendations, scope: 'quality' } only %}
