{#
    Two-column body of the dashboard: top queries / zero-results on the left,
    coverage chart / recent errors on the right.

    Params:
        topQueries     iterable
        zeroResults    iterable
        coverage       iterable
        coverageTotal  int
        recentErrors   iterable
#}
<div class="dashboard__cols">
    <div class="card">
        <h3 class="card__title">Top queries (7d)</h3>
        {% if topQueries|length %}
            <table class="mini-table">
                {% for q in topQueries %}
                    <tr>
                        <td>{{ q.query }}</td>
                        <td>{{ q.hits }} hit{{ q.hits == 1 ? '' : 's' }}</td>
                    </tr>
                {% endfor %}
            </table>
            <p class="card__cta"><a class="go" href="{{ cpUrl('ai-search/insights') }}">View all queries</a></p>
        {% else %}
            <p class="card__empty">No search activity in the last 7 days.</p>
        {% endif %}

        <h3 class="card__title card__title--section">Zero-result queries (7d)</h3>
        {% if zeroResults|length %}
            <table class="mini-table">
                {% for q in zeroResults %}
                    <tr>
                        <td>{{ q.query }}</td>
                        <td>{{ q.hits }}×</td>
                    </tr>
                {% endfor %}
            </table>
        {% else %}
            <p class="card__empty">No zero-result queries — nice.</p>
        {% endif %}
    </div>

    <div class="card">
        <h3 class="card__title">Coverage by site</h3>
        {% if coverage|length and coverageTotal > 0 %}
            <div class="card__chart">
                <canvas data-craftsearch-chart="stacked-bar" data-craftsearch-series="{{ coverage|json_encode|e('html_attr') }}"></canvas>
            </div>
        {% else %}
            <p class="card__empty">No entries indexed yet.</p>
        {% endif %}

        <h3 class="card__title card__title--section">Recent errors</h3>
        {% if recentErrors|length %}
            <table class="mini-table">
                {% for e in recentErrors %}
                    <tr>
                        <td>
                            <a href="{{ cpUrl('ai-search/insights/' ~ e.id) }}">{{ (e.query ?: e.errorMessage ?: 'error')|slice(0, 60) }}</a>
                        </td>
                        <td>{{ e.dateCreated|date('M j, g:i A') }}</td>
                    </tr>
                {% endfor %}
            </table>
        {% else %}
            <p class="card__empty">No errors recorded.</p>
        {% endif %}
    </div>
</div>
