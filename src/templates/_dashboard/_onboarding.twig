{#
    Onboarding card shown on the dashboard until setup is complete.

    Params:
        settings  Plugin settings model
        stats     { isConnected, entryCount }
#}
{% set steps = [
    { done: settings.openaiApiKey ? true : false, label: 'Configure your OpenAI API key', hint: 'Generate embeddings and power RAG search.', cta: 'smart-search/settings' },
    { done: stats.isConnected, label: 'Connect your PostgreSQL / pgvector database', hint: 'Stores embeddings for fast semantic lookup.', cta: 'smart-search/settings' },
    { done: stats.isConnected and stats.entryCount > 0, label: 'Run your first index', hint: 'Generates vectors for every published entry.', cta: 'smart-search/index' },
] %}

<div class="pane">
    <h2 class="dash-lede">Finish setting up Smart Search</h2>
    <p class="light dash-lede">Three steps separate you from intelligent, AI-powered search on your Craft site.</p>

    <ol class="onboarding-list">
        {% for s in steps %}
            <li class="onboarding-list__item{% if s.done %} onboarding-list__item--done{% endif %}">
                <span class="onboarding-list__icon">
                    {% if s.done %}<span data-icon="check"></span>{% else %}{{ loop.index }}{% endif %}
                </span>
                <div>
                    <strong>{{ s.label }}</strong>
                    <div class="light smalltext">{{ s.hint }}</div>
                </div>
                {% if not s.done %}
                    <a class="btn submit" href="{{ cpUrl(s.cta) }}">Open</a>
                {% endif %}
            </li>
        {% endfor %}
    </ol>
</div>
