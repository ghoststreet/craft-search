{#
    KPI hero strip: Searches, Cost, Coverage, Avg response time.

    Params:
        aggregates       { searches30, searchesDelta, cost30, costDelta, avgDurationMs, errors30 }
        seriesSearches   array  sparkline data
        seriesCost       array  area chart data
        seriesDuration   array  duration chart data
        coverageTotals   { indexed, stale, notIndexed }
        coverageTotal    int
        coveragePct      int
        budget           { cap, spent, ratio, etaDays }
        budgetClass      string  budget-bar BEM modifier ('budget-bar--warn' | 'budget-bar--crit' | '')
        budgetPct        int
#}
{% import 'ai-search/_components/delta-tag' as ui %}

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-card__label">Searches (30d)</div>
        <div class="kpi-card__value">{{ aggregates.searches30|number_format }}</div>
        <div>{{ ui.deltaTag(aggregates.searchesDelta) }} <span class="kpi-card__sub">vs prior 15d</span></div>
        <div class="kpi-card__chart">
            <canvas data-craftsearch-chart="sparkline" data-craftsearch-series="{{ seriesSearches|json_encode|e('html_attr') }}"></canvas>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-card__label">Cost (30d)</div>
        <div class="kpi-card__value">${{ aggregates.cost30|number_format(4) }}</div>
        <div>
            {{ ui.deltaTag(aggregates.costDelta) }}
            {% if budget.cap > 0 %}
                <span class="kpi-card__sub">Today: ${{ budget.spent|number_format(4) }} / ${{ budget.cap|number_format(2) }}</span>
            {% endif %}
        </div>
        <div class="kpi-card__chart">
            <canvas data-craftsearch-chart="area" data-craftsearch-series="{{ seriesCost|json_encode|e('html_attr') }}"></canvas>
        </div>
        {% if budget.cap > 0 %}
            <div class="budget-bar{% if budgetClass %} {{ budgetClass }}{% endif %}" title="{{ budgetPct }}% of daily cap used">
                <span class="budget-bar__fill" style="width: {{ budgetPct }}%"></span>
            </div>
            {% if budget.etaDays is not null and budget.etaDays < 30 %}
                <div class="kpi-card__eta">Projected to hit cap in ~{{ budget.etaDays }} days</div>
            {% endif %}
        {% endif %}
    </div>

    <div class="kpi-card kpi-card--donut">
        <div class="kpi-card__label">Index Coverage</div>
        <div class="kpi-card__value">{{ coveragePct }}%</div>
        <div class="kpi-card__meta">{{ coverageTotals.indexed|number_format }} / {{ coverageTotal|number_format }} entries</div>
        <div class="kpi-card__chart">
            <canvas data-craftsearch-chart="donut" data-craftsearch-series="{{ coverageTotals|json_encode|e('html_attr') }}"></canvas>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-card__label">Avg Response Time</div>
        <div class="kpi-card__value">{{ aggregates.avgDurationMs|number_format }}<span class="kpi-card__value-unit"> ms</span></div>
        <div class="kpi-card__meta">
            {% if aggregates.errors30 > 0 %}
                <span class="kpi-card__error">{{ aggregates.errors30 }} errors</span>
            {% else %}
                No errors recorded
            {% endif %}
        </div>
        <div class="kpi-card__chart">
            <canvas data-craftsearch-chart="duration" data-craftsearch-series="{{ seriesDuration|json_encode|e('html_attr') }}"></canvas>
        </div>
    </div>
</div>
