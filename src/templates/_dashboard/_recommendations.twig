{#
    Recommendations card (only rendered when there are any).

    Params:
        recommendations  iterable of { level, title, body, cta? }
#}
{% if recommendations|length %}
    <div class="card recommendation-list">
        <h3 class="card__title">Recommendations</h3>
        <ul class="recommendation-list__items">
            {% for r in recommendations %}
                <li>
                    <span class="recommendation-list__level recommendation-list__level--{{ r.level }}">{{ r.level }}</span>
                    <strong>{{ r.title }}.</strong>
                    <span class="recommendation-list__body">{{ r.body }}</span>
                    {% if r.cta %}<a class="recommendation-list__cta" href="{{ r.cta.url }}">{{ r.cta.label }} →</a>{% endif %}
                </li>
            {% endfor %}
        </ul>
    </div>
{% endif %}
