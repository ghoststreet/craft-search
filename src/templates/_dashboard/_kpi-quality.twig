{#
    KPI strip for the Search Quality tab: Searches · Zero-result rate · Cache hit rate.

    Params:
        aggregates       { searches, searchesDelta, rangeDays, priorWindowDays }
        seriesSearches   array  sparkline data
        zeroResultRate   ?float 0..1
        cacheHitRate     ?float 0..1
        seriesZero       array  daily zero-result counts
        minNRate         int    minimum sample size before a rate becomes meaningful
        minNDelta        int    minimum sample size before a delta becomes meaningful
#}
{% import 'ai-search/_components/delta-tag' as ui %}

<div class="kpi-grid kpi-grid--3">
    <div class="kpi-card">
        <div class="kpi-card__label">Searches ({{ aggregates.rangeDays }}d)</div>
        <div class="kpi-card__value">{{ aggregates.searches|number_format }}</div>
        <div>
            {% if aggregates.searches >= minNDelta %}
                {{ ui.deltaTag(aggregates.searchesDelta) }}
                <span class="kpi-card__sub">vs previous {{ aggregates.priorWindowDays }}d</span>
            {% else %}
                <span class="kpi-card__sub">Need ≥{{ minNDelta }} searches for trend</span>
            {% endif %}
        </div>
        <div class="kpi-card__chart">
            <canvas data-craftsearch-chart="sparkline" data-craftsearch-series="{{ seriesSearches|json_encode|e('html_attr') }}"></canvas>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-card__label">Zero-result rate</div>
        {% if zeroResultRate is null %}
            <div class="kpi-card__value kpi-card__value--muted">—</div>
            <div class="kpi-card__meta">No searches recorded yet</div>
        {% elseif aggregates.searches < minNRate %}
            <div class="kpi-card__value kpi-card__value--muted">{{ (zeroResultRate * 100)|round(1) }}%</div>
            <div class="kpi-card__meta">Low sample ({{ aggregates.searches }}/{{ minNRate }}) — rate is noisy</div>
        {% else %}
            <div class="kpi-card__value">{{ (zeroResultRate * 100)|round(1) }}%</div>
            <div class="kpi-card__meta">
                {% if zeroResultRate >= 0.4 %}<span class="kpi-card__error">High — likely missing content</span>
                {% elseif zeroResultRate >= 0.2 %}Slightly elevated
                {% else %}Healthy
                {% endif %}
            </div>
        {% endif %}
        <div class="kpi-card__chart">
            <canvas data-craftsearch-chart="sparkline" data-craftsearch-series="{{ seriesZero|json_encode|e('html_attr') }}"></canvas>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-card__label">Embedding cache hit rate</div>
        {% if cacheHitRate is null %}
            <div class="kpi-card__value kpi-card__value--muted">—</div>
            <div class="kpi-card__meta">No searches recorded yet</div>
        {% elseif aggregates.searches < minNRate %}
            <div class="kpi-card__value kpi-card__value--muted">{{ (cacheHitRate * 100)|round(1) }}%</div>
            <div class="kpi-card__meta">Low sample ({{ aggregates.searches }}/{{ minNRate }}) — rate is noisy</div>
        {% else %}
            <div class="kpi-card__value">{{ (cacheHitRate * 100)|round(1) }}%</div>
            <div class="kpi-card__meta">
                {% if cacheHitRate >= 0.4 %}Strong reuse — saving cost
                {% elseif cacheHitRate >= 0.15 %}Moderate reuse
                {% else %}Low — consider raising cache TTL
                {% endif %}
            </div>
        {% endif %}
    </div>
</div>
