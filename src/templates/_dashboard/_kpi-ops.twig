{#
    KPI strip for the Operations tab: Spend · p95 latency · Index freshness.

    Params:
        aggregates        { cost, costDelta, p95DurationMs, avgDurationMs, errors, rangeDays, searches, priorWindowDays }
        seriesCost        array  area data
        seriesDuration    array  duration data
        budget            { cap, spent, ratio, etaDays }
        budgetClass       string
        budgetPct         int
        stats             { isConnected, lastIndexed }
        coveragePct       int
        daysWithData      int    days in the window with at least one search
        minNRate          int
        minNDelta         int
        minDaysBudgetEta  int    days of data required before the budget ETA is meaningful
#}
{% import 'ai-search/_components/delta-tag' as ui %}

<div class="kpi-grid kpi-grid--3">
    <div class="kpi-card">
        <div class="kpi-card__label">Spend ({{ aggregates.rangeDays }}d)</div>
        <div class="kpi-card__value">${{ aggregates.cost|number_format(2) }}</div>
        <div>
            {% if aggregates.searches >= minNDelta %}
                {{ ui.deltaTag(aggregates.costDelta) }}
                <span class="kpi-card__sub">vs previous {{ aggregates.priorWindowDays }}d</span>
            {% elseif budget.cap > 0 %}
                <span class="kpi-card__sub">Today: ${{ budget.spent|number_format(2) }} / ${{ budget.cap|number_format(2) }}</span>
            {% else %}
                <span class="kpi-card__sub">No daily cap set</span>
            {% endif %}
        </div>
        <div class="kpi-card__chart">
            <canvas data-craftsearch-chart="area" data-craftsearch-series="{{ seriesCost|json_encode|e('html_attr') }}"></canvas>
        </div>
        {% if budget.cap > 0 %}
            <div class="budget-bar{% if budgetClass %} {{ budgetClass }}{% endif %}" title="{{ budgetPct }}% of daily cap used">
                <span class="budget-bar__fill" style="width: {{ budgetPct }}%"></span>
            </div>
            {% if budget.etaDays is not null and budget.etaDays < 30 and daysWithData >= minDaysBudgetEta %}
                <div class="kpi-card__eta">Projected to hit cap in ~{{ budget.etaDays }} days</div>
            {% endif %}
        {% endif %}
    </div>

    <div class="kpi-card">
        <div class="kpi-card__label">p95 response time</div>
        {% if aggregates.searches < minNRate %}
            <div class="kpi-card__value kpi-card__value--muted">{{ aggregates.p95DurationMs|number_format }}<span class="kpi-card__value-unit"> ms</span></div>
            <div class="kpi-card__meta">Low sample ({{ aggregates.searches }}/{{ minNRate }}) — p95 is noisy</div>
        {% else %}
            <div class="kpi-card__value">{{ aggregates.p95DurationMs|number_format }}<span class="kpi-card__value-unit"> ms</span></div>
            <div class="kpi-card__meta">
                Avg {{ aggregates.avgDurationMs|number_format }} ms
                {% if aggregates.errors > 0 %} · <span class="kpi-card__error">{{ aggregates.errors }} errors</span>{% endif %}
            </div>
        {% endif %}
        <div class="kpi-card__chart">
            <canvas data-craftsearch-chart="duration" data-craftsearch-series="{{ seriesDuration|json_encode|e('html_attr') }}"></canvas>
        </div>
    </div>

    <div class="kpi-card">
        <div class="kpi-card__label">Index coverage</div>
        <div class="kpi-card__value">{{ coveragePct }}<span class="kpi-card__value-unit">% indexed</span></div>
        <div class="kpi-card__meta">
            {% if stats.lastIndexed %}
                Last sync {{ stats.lastIndexed|date('M j, g:i A') }}
            {% else %}
                Never synced — <a href="{{ cpUrl('ai-search/index') }}">run a sync →</a>
            {% endif %}
        </div>
    </div>
</div>
