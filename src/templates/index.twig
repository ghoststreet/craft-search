{% extends "_layouts/cp" %}

{% set title = 'AI Search' %}

{# Build the chart series upfront so the KPI grid partial stays presentation-only. #}
{% set seriesSearches = [] %}
{% set seriesCost = [] %}
{% set seriesDuration = [] %}
{% for r in dailySeries %}
    {% set seriesSearches = seriesSearches|merge([{ date: r.date, value: r.searches }]) %}
    {% set seriesCost = seriesCost|merge([{ date: r.date, value: r.cost }]) %}
    {% set seriesDuration = seriesDuration|merge([{ date: r.date, avg: r.avgMs, p95: r.p95Ms }]) %}
{% endfor %}

{% set coverageTotals = { indexed: 0, stale: 0, notIndexed: 0 } %}
{% for c in coverage %}
    {% set coverageTotals = {
        indexed: coverageTotals.indexed + c.indexed,
        stale: coverageTotals.stale + c.stale,
        notIndexed: coverageTotals.notIndexed + c.notIndexed,
    } %}
{% endfor %}
{% set coverageTotal = coverageTotals.indexed + coverageTotals.stale + coverageTotals.notIndexed %}
{% set coveragePct = coverageTotal > 0 ? (coverageTotals.indexed / coverageTotal * 100)|round : 0 %}

{% set budgetClass = budget.ratio >= 0.9 ? 'crit' : (budget.ratio >= 0.75 ? 'warn' : '') %}
{% set budgetPct = (budget.ratio * 100)|round %}

{% block content %}
<div class="aisearch-dash">

    {% if not setupComplete %}
        {% include 'ai-search/_dashboard/_onboarding' with { settings: settings, stats: stats } only %}

    {% else %}

        {# Critical alerts: only show top-priority advisory as full banner #}
        {% set criticals = recommendations|filter(r => r.level == 'crit') %}
        {% if criticals|length %}
            {% set top = criticals|first %}
            <div class="aisearch-alert">
                <strong>{{ top.title }}.</strong> {{ top.body }}
                {% if top.cta %} <a href="{{ top.cta.url }}">{{ top.cta.label }} →</a>{% endif %}
            </div>
        {% endif %}

        {% include 'ai-search/_dashboard/_kpi-grid' with {
            aggregates: aggregates,
            seriesSearches: seriesSearches,
            seriesCost: seriesCost,
            seriesDuration: seriesDuration,
            coverageTotals: coverageTotals,
            coverageTotal: coverageTotal,
            coveragePct: coveragePct,
            budget: budget,
            budgetClass: budgetClass,
            budgetPct: budgetPct,
        } only %}

        {% include 'ai-search/_dashboard/_health-row' with {
            settings: settings,
            stats: stats,
            coveragePct: coveragePct,
            budget: budget,
            budgetPct: budgetPct,
        } only %}

        {% include 'ai-search/_dashboard/_body-cards' with {
            topQueries: topQueries,
            zeroResults: zeroResults,
            coverage: coverage,
            coverageTotal: coverageTotal,
            recentErrors: recentErrors,
        } only %}

        {% include 'ai-search/_dashboard/_recommendations' with { recommendations: recommendations } only %}

    {% endif %}
</div>
{% endblock %}
