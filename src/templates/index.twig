{% extends "_layouts/cp" %}

{% set title = 'AI Search' %}

{# Native CP layout tabs — _layouts/cp.twig reads the `tabs` and `selectedTab` vars
   and renders them in the page header via _includes/tabs.twig, identical to the
   pattern used by Settings, Fields, and the rest of the CP. Only shown when the
   plugin is set up (otherwise the onboarding card replaces everything). #}
{% if setupComplete ?? false %}
    {% set tabs = {
        quality: { label: 'Search Quality'|t('ai-search'), url: cpUrl('ai-search', { range: range, tab: 'quality' }) },
        advanced: { label: 'Advanced'|t('ai-search'), url: cpUrl('ai-search', { range: range, tab: 'advanced' }) },
    } %}
    {% set selectedTab = tab %}
{% endif %}

{# Build chart-friendly series upfront so partials stay presentation-only. #}
{% set seriesSearches = [] %}
{% set seriesCost = [] %}
{% set seriesDuration = [] %}
{% set seriesZero = [] %}
{% for r in dailySeries %}
    {% set seriesSearches = seriesSearches|merge([{ date: r.date, value: r.searches }]) %}
    {% set seriesCost = seriesCost|merge([{ date: r.date, value: r.cost }]) %}
    {% set seriesDuration = seriesDuration|merge([{ date: r.date, avg: r.avgMs, p95: r.p95Ms }]) %}
    {% set seriesZero = seriesZero|merge([{ date: r.date, value: r.zeroResults }]) %}
{% endfor %}

{% set coverageTotals = { indexed: 0, stale: 0, notIndexed: 0 } %}
{% for c in coverage %}
    {% set coverageTotals = {
        indexed: coverageTotals.indexed + c.indexed,
        stale: coverageTotals.stale + c.stale,
        notIndexed: coverageTotals.notIndexed + c.notIndexed,
    } %}
{% endfor %}
{% set coverageTotal = coverageTotals.indexed + coverageTotals.stale + coverageTotals.notIndexed %}
{% set coveragePct = coverageTotal > 0 ? (coverageTotals.indexed / coverageTotal * 100)|round : 0 %}

{% set budgetClass = budget.ratio >= 0.9 ? 'budget-bar--crit' : (budget.ratio >= 0.75 ? 'budget-bar--warn' : '') %}
{% set budgetPct = (budget.ratio * 100)|round %}

{% block content %}
<div class="dashboard">

    {% if not setupComplete %}
        {% include 'ai-search/_dashboard/_onboarding' with { settings: settings, stats: stats } only %}

    {% else %}

        {# Critical alerts — render every crit, not just the first. #}
        {% set criticals = recommendations|filter(r => r.level == 'crit') %}
        {% for c in criticals %}
            <div class="alert" role="alert">
                <strong>{{ c.title }}.</strong> {{ c.body }}
                {% if c.cta %} <a href="{{ c.cta.url }}">{{ c.cta.label }} →</a>{% endif %}
            </div>
        {% endfor %}

        {# Range picker — sits in its own toolbar row below the native tabs. #}
        <div class="flex flex-justify">
            <span></span>
            {% include 'ai-search/_dashboard/_range-picker' with { range: range, allowedRanges: allowedRanges, tab: tab } only %}
        </div>

        {% if tab == 'advanced' %}
            {% include 'ai-search/_dashboard/_ops-tab' with _context only %}
        {% else %}
            {% include 'ai-search/_dashboard/_quality-tab' with _context only %}
        {% endif %}

        {# Data freshness disclosure — surface server timezone and "includes admin searches" caveat. #}
        <p class="dashboard__as-of light smalltext">
            As of {{ dataAsOf|date('M j, g:i A') }} ({{ dataAsOf|date('T') }}).
            Counts include searches issued from the control panel.
            Coverage may lag by up to 60s.
        </p>

    {% endif %}
</div>
{% endblock %}
